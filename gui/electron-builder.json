{
  "appId": "de.gfos.build",
  "productName": "GFOS Build",
  "asar": true,
  "asarUnpack": [
    "**/node_modules/better-sqlite3/**/*"
  ],
  "directories": {
    "output": "../release/gui"
  },
  "files": [
    "out/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "../assets/icon.ico",
    "sign": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "forceCodeSigning": false
}
