{
  "name": "gfos-build",
  "version": "3.1.0",
  "description": "Foundation CLI for Maven repository discovery and builds",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "gfos-build": "dist/cli/index.js"
  },
  "author": "GFOS",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli/index.js",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "binary:build": "bun run binary:build:win",
    "binary:smoke": "bun run scripts/smoke-binary.ts",
    "check:all": "bun run check && bun run binary:build:native && bun run binary:smoke && bun run binary:build:win",
    "binary:build:native": "bun build --compile src/cli/index.ts --outfile release/gfos-build",
    "binary:build:win": "bun build --compile --target=bun-windows-x64-modern src/cli/index.ts --outfile release/gfos-build.exe"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
