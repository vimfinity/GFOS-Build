{
  "name": "gfos-build",
  "version": "2.0.0",
  "description": "GFOS Build - Maven Build Manager",
  "main": "dist/main/main/index.js",
  "author": "GFOS",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently -n main,renderer -c blue,green \"bun run dev:main\" \"bun run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "bun run build:renderer && bun run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "package": "bun run build && electron-builder",
    "package:win": "bun run build && electron-builder --win --x64",
    "package:linux": "bun run build && electron-builder --linux --x64",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "framer-motion": "^12.31.0",
    "fs-extra": "^11.3.2",
    "zod": "^3.24.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@testing-library/react": "^16.1.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.14.0",
    "happy-dom": "^16.6.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "trustedDependencies": [
    "@swc/core"
  ]
}
