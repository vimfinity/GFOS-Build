{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gfos-build.local/schemas/run-report.v1.1.json",
  "title": "GFOS Build Run Report v1.1",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "command",
    "mode",
    "startedAt",
    "finishedAt",
    "durationMs",
    "discovered",
    "moduleGraph",
    "profileScan",
    "buildResults",
    "events",
    "stats"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.1"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "enum": [
        "scan",
        "build",
        "pipeline"
      ]
    },
    "mode": {
      "enum": [
        "scan",
        "build-plan",
        "build-run",
        "pipeline-lint",
        "pipeline-plan",
        "pipeline-run"
      ]
    },
    "durationMs": {
      "type": "number",
      "minimum": 0
    },
    "comparison": {
      "type": "object",
      "required": [
        "previousRunId",
        "previousDurationMs",
        "durationDeltaMs"
      ],
      "properties": {
        "previousRunId": {
          "type": "string"
        },
        "previousDurationMs": {
          "type": "number"
        },
        "durationDeltaMs": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "stats": {
      "type": "object",
      "required": [
        "discoveredCount",
        "plannedCount",
        "builtCount",
        "succeededCount",
        "failedCount",
        "totalBuildDurationMs",
        "failedBuildDurationMs",
        "maxParallelUsed",
        "profileCount",
        "discoveryDurationMs"
      ],
      "additionalProperties": false,
      "properties": {
        "discoveredCount": {
          "type": "number",
          "minimum": 0
        },
        "plannedCount": {
          "type": "number",
          "minimum": 0
        },
        "builtCount": {
          "type": "number",
          "minimum": 0
        },
        "succeededCount": {
          "type": "number",
          "minimum": 0
        },
        "failedCount": {
          "type": "number",
          "minimum": 0
        },
        "totalBuildDurationMs": {
          "type": "number",
          "minimum": 0
        },
        "failedBuildDurationMs": {
          "type": "number",
          "minimum": 0
        },
        "maxParallelUsed": {
          "type": "number",
          "minimum": 1
        },
        "profileCount": {
          "type": "number",
          "minimum": 0
        },
        "discoveryDurationMs": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "startedAt": {
      "type": "string",
      "minLength": 1
    },
    "finishedAt": {
      "type": "string",
      "minLength": 1
    },
    "events": {
      "type": "array",
      "minItems": 1
    },
    "selectionExplanation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "repositoryPath",
          "selected",
          "reason"
        ],
        "properties": {
          "repositoryPath": {
            "type": "string",
            "minLength": 1
          },
          "selected": {
            "type": "boolean"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "discovered": {
      "type": "array"
    },
    "moduleGraph": {
      "type": "object"
    },
    "profileScan": {
      "type": "object"
    },
    "buildResults": {
      "type": "array"
    },
    "buildPlan": {
      "type": "object"
    },
    "pipeline": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
