{
  "name": "gfos-build",
  "version": "0.1.0-alpha.1",
  "description": "CLI for Maven build orchestration and pipeline automation",
  "type": "module",
  "private": true,
  "workspaces": [
    "gui",
    "shared"
  ],
  "bin": {
    "gfos-build": "dist/cli/index.js"
  },
  "author": "GFOS",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "dev:gui": "cd gui && bun run dev",
    "rebuild:native": "cd gui && bun run rebuild:native",
    "build": "tsc -p tsconfig.json",
    "build:server": "tsdown",
    "build:gui": "bun run build:server && bun run binary:build:win && cd gui && bun run package",
    "start": "node dist/cli/index.js",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:gui": "cd gui && bun run typecheck",
    "test": "vitest run",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "check:gui": "cd gui && bun run build",
    "check:all": "bun run check && bun run build:server && bun run check:gui",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "binary:build": "bun run binary:build:win",
    "binary:smoke": "bun run scripts/smoke-binary.ts",
    "binary:build:native": "bun build --compile src/cli/index.ts --outfile release/gfos-build",
    "binary:build:win": "bun build --compile --target=bun-windows-x64-modern src/cli/index.ts --outfile release/gfos-build.exe"
  },
  "dependencies": {
    "@gfos-build/shared": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsdown": "^0.20.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
