{
  "name": "gfos-build",
  "version": "0.1.0-alpha.2",
  "description": "CLI for Maven build orchestration and pipeline automation",
  "type": "module",
  "private": true,
  "workspaces": [
    "gui",
    "shared"
  ],
  "bin": {
    "gfos-build": "dist/cli/index.js"
  },
  "author": "GFOS",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "dev:desktop": "cd gui && bun run dev",
    "start": "bun run dist/cli/index.js",
    "start:desktop": "cd gui && bun run start",
    "smoke:desktop": "cd gui && bun run smoke:win",
    "build": "tsc -p tsconfig.json",
    "build:desktop": "cd gui && bun run build",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:desktop": "cd gui && bun run typecheck",
    "test": "vitest run",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build",
    "check:desktop": "cd gui && bun run check",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "dist:desktop:win": "cd gui && bun run dist:win"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "electron"
  ],
  "dependencies": {
    "@gfos-build/shared": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bun": "latest",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.0"
  }
}
