{
  "name": "gfos-build-gui",
  "productName": "GFOS Build",
  "version": "0.1.0-alpha.4",
  "description": "GFOS Build — Desktop GUI",
  "author": "GFOS",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "node scripts/start-win.mjs",
    "smoke:win": "node scripts/start-win.mjs --smoke-test",
    "check": "bun run typecheck && bun run build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dist:win": "node scripts/dist-win.mjs && bunx electron-builder --config electron-builder.yml --win nsis --x64 --publish never",
    "dist:win:portable": "node scripts/dist-win.mjs",
    "dist:win:installer": "bunx electron-builder --config electron-builder.yml --win nsis --x64 --publish never",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "node node_modules/electron/install.js && bun run rebuild:native"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.95.0",
    "better-sqlite3": "^11.7.0",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.12.3",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@electron/rebuild": "^3.7.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/router-plugin": "^1.95.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1"
  }
}
