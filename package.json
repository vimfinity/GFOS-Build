{
  "name": "gfos-build",
  "version": "0.1.0-alpha.6",
  "description": "CLI for Maven build orchestration and pipeline automation",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=24 <25",
    "bun": ">=1.3.10"
  },
  "overrides": {
    "rollup": "4.59.0",
    "minimatch": "10.2.4",
    "ajv": "6.14.0",
    "flatted": "3.4.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "gfos-build": "apps/cli/dist/index.js"
  },
  "author": "GFOS",
  "license": "MIT",
  "scripts": {
    "dev": "bun run apps/cli/src/index.ts",
    "dev:desktop": "cd apps/desktop && bun run dev",
    "start": "node apps/cli/dist/index.js",
    "start:desktop": "cd apps/desktop && bun run start",
    "smoke:desktop": "cd apps/desktop && bun run smoke:win",
    "release:smoke": "bun run smoke:desktop",
    "build:contracts": "tsc -p packages/contracts/tsconfig.json",
    "build:domain": "tsc -p packages/domain/tsconfig.json",
    "build:application": "tsc -p packages/application/tsconfig.json",
    "build:platform-node": "tsc -p packages/platform-node/tsconfig.json",
    "build:cli": "tsc -p apps/cli/tsconfig.json",
    "build": "bun run build:contracts && bun run build:domain && bun run build:application && bun run build:platform-node && bun run build:cli",
    "build:desktop": "bun run build && cd apps/desktop && bun run build",
    "lint": "eslint apps packages tests",
    "typecheck:contracts": "tsc --noEmit -p packages/contracts/tsconfig.json",
    "typecheck:domain": "tsc --noEmit -p packages/domain/tsconfig.json",
    "typecheck:application": "tsc --noEmit -p packages/application/tsconfig.json",
    "typecheck:platform-node": "tsc --noEmit -p packages/platform-node/tsconfig.json",
    "typecheck:cli": "tsc --noEmit -p apps/cli/tsconfig.json",
    "typecheck": "bun run typecheck:contracts && bun run typecheck:domain && bun run typecheck:application && bun run typecheck:platform-node && bun run typecheck:cli",
    "typecheck:desktop": "bun run typecheck && cd apps/desktop && bun run typecheck",
    "test": "vitest run",
    "check": "bun run lint && bun run build && bun run typecheck && bun run test",
    "check:desktop": "bun run check && cd apps/desktop && bun run check",
    "format": "prettier --write \"apps/**/*.ts\" \"apps/**/*.tsx\" \"packages/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "format:check": "prettier --check \"apps/**/*.ts\" \"apps/**/*.tsx\" \"packages/**/*.ts\" \"tests/**/*.ts\" \"*.md\"",
    "dist:desktop:win": "bun run build && cd apps/desktop && bun run dist:win"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
