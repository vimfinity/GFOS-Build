{
  "name": "@gfos-build/desktop",
  "productName": "GFOS Build",
  "version": "0.1.0-alpha.5",
  "description": "GFOS Build — Desktop GUI",
  "author": "GFOS",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "node scripts/start-win.mjs",
